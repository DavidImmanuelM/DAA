#include <iostream>
using namespace std;
void printArray(int arr[], int size) {
    for(int i = 0; i < size; i++)
        cout << arr[i] << " ";
    cout << endl;
}
void swap(int &a, int &b) {
    int t = a;
    a = b;
    b = t;
}
int partition(int arr[], int low, int high, int totalSize) {
    int pivot = arr[high];
    int i = low - 1;

    for(int j = low; j <= high - 1; j++) {
        if(arr[j] <= pivot) {
            i++;
            swap(arr[i], arr[j]);
        }
    }
    swap(arr[i + 1], arr[high]);
    return i + 1;
}
void quickSort(int arr[], int low, int high, int totalSize) {
    if(low < high) {
        int pi = partition(arr, low, high, totalSize);

        cout << "Pivot [" << arr[pi] << "] positioned: ";
        printArray(arr, totalSize);

        quickSort(arr, low, pi - 1, totalSize);
        quickSort(arr, pi + 1, high, totalSize);
    }
}
int main() {
    int n;
    cout << "Enter number of elements: ";
    cin >> n;
    int arr[100];
    cout << "Enter elements: ";
    for(int i = 0; i < n; i++)
        cin >> arr[i];
    quickSort(arr, 0, n - 1, n);

    cout << "Sorted Array: ";
    printArray(arr, n);

    return 0;
}
