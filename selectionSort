#include<stdio.h>
int main(){
   int i,j,min,temp,n;
   printf("Enter number of elements:");
   scanf("%d",&n);
   int A[n];
   printf("Enter array elements:\n");
   for(i=0;i<n;i++){
      printf("Enter Element %d :",i+1);
      scanf("%d",&A[i]);
   }
   for(i=0;i<=n-2;i++){
      min = i;
      for(j=i+1;j<=n-1;j++){
         if(A[j] < A[min]){
            min = j;
         }
      }
      temp = A[i];
      A[i] = A[min];
      A[min] = temp;
   }
   printf("Sorted array using selection sort: ");
   for(i=0;i<n;i++){
      printf(" %d",A[i]);
   }
   printf("\n");
   return 0;
}
