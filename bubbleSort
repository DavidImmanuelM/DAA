#include<stdio.h>
int main(){
   int i,j,temp,n;
   printf("Enter number of elements:");
   scanf("%d",&n);
   int A[n];
   printf("Enter array elements:\n");
   for(i=0;i<n;i++){
      printf("Enter element %d :",i+1);
      scanf("%d",&A[i]);
   }
   for(i=0;i<=n-2;i++){
      for(j=0;j<=n-2-i;j++){
         if(A[j+1] < A[j]){
            temp = A[j];
            A[j] = A[j+1];
            A[j+1] = temp;
         }
      }
   }
   printf("Sorted arrary using bubble sort:");
   for(i=0;i<n;i++){
      printf(" %d",A[i]);
   }
   printf("\n");
   return 0;
}
