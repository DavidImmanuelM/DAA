#include <iostream>
#include <string>
using namespace std;
int main() {
    string text, pattern;
    int found = 0;
    cout << "Enter the text: ";
    cin >> text;
    cout << "Enter the pattern: ";
    cin >> pattern;
    int n = text.length();
    int m = pattern.length();
    for (int i = 0; i <= n - m; i++) {
        int j = 0;
        while (j < m && text[i + j] == pattern[j]) {
            j++;
        }
        if (j == m) {
            cout << "Pattern found at position " << i << endl;
            found = 1;
        }
    }
    if (!found) {
        cout << "Pattern not found" << endl;
    }
    return 0;
}
